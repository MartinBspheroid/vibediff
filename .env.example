# VibeDiff environment variables (all optional).
# Copy to .env for local reference; VibeDiff reads these from the environment.

# Set to "true" to enable verbose debug logging.
VIBEDIFF_DEBUG=false

# Set to any non-empty value to disable automatic browser opening
# (useful in CI/headless environments). Equivalent to the -no-open flag.
VIBEDIFF_NO_OPEN=
